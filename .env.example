# MythCoder 环境变量配置
# 复制此文件为 .env 并填入实际值，或直接在 shell 中 export 这些变量

# DeepSeek API Key（必填，除非使用其他模型）
MYTHCODER_API_KEY=sk-your-deepseek-api-key-here

# 可选：其他模型供应商的 API Key
# OPENAI_API_KEY=sk-your-openai-api-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# QWEN_API_KEY=sk-your-qwen-api-key
# ZHIPU_API_KEY=your-zhipu-api-key
